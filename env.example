# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost/knowledgeops
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM — xAI Grok (https://console.x.ai)
# Create a free account and generate a key from the API Keys section
XAI_API_KEY=xai-your-key-here
XAI_MODEL=grok-beta

# Embeddings — runs locally via sentence-transformers, no API key needed
# Model downloads automatically on first run (~440 MB)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Vector Database
VECTOR_DB_URL=postgresql+asyncpg://user:password@localhost/vectordb

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Celery Configuration
CELERY_CONCURRENCY=2
CELERY_QUEUE=document_processing

# CrewAI — self-call URL for the Retrieval Specialist's search tool.
# Local dev: http://localhost:8000  |  Docker Compose: http://app:8000
# Leave empty to disable targeted re-retrieval during crew runs.
API_BASE_URL=
